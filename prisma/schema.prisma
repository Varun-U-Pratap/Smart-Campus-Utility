generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueCategory {
  ELECTRICAL
  PLUMBING
  NETWORK
  CLEANLINESS
  SECURITY
  OTHER
}

enum AnnouncementCategory {
  GENERAL
  ACADEMIC
  EVENT
  EMERGENCY
  MAINTENANCE
}

enum AnnouncementVisibility {
  PUBLIC
  STUDENTS_ONLY
  ADMINS_ONLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum RoomType {
  CLASSROOM
  LAB
  AUDITORIUM
  MEETING_ROOM
  OTHER
}

enum NotificationType {
  ANNOUNCEMENT
  ISSUE_UPDATE
  BOOKING_UPDATE
  SYSTEM
}

model User {
  id                       String             @id @default(uuid())
  email                    String             @unique
  passwordHash             String
  fullName                 String
  role                     Role               @default(STUDENT)
  isActive                 Boolean            @default(true)
  phoneNumber              String?
  avatarUrl                String?
  studentProfile           StudentProfile?
  adminProfile             AdminProfile?
  issuesReported           Issue[]            @relation("IssueReporter")
  issuesAssigned           Issue[]            @relation("IssueAssignee")
  issueComments            IssueComment[]
  issueActivities          IssueActivity[]    @relation("IssueActor")
  uploadedIssueAttachments IssueAttachment[]  @relation("IssueAttachmentUploader")
  announcementsAuthored    Announcement[]     @relation("AnnouncementAuthor")
  announcementReads        AnnouncementRead[]
  bookings                 Booking[]          @relation("BookingRequester")
  approvedBookings         Booking[]          @relation("BookingApprover")
  notifications            Notification[]
  refreshTokens            RefreshToken[]
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([role, isActive])
  @@index([createdAt])
}

model StudentProfile {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId   String   @unique
  department  String
  program     String?
  year        Int?
  section     String?
  hostelBlock String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminProfile {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode String   @unique
  department   String?
  designation  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model Issue {
  id          String            @id @default(uuid())
  ticketNo    String            @unique
  title       String
  description String
  category    IssueCategory
  priority    IssuePriority     @default(MEDIUM)
  status      IssueStatus       @default(OPEN)
  building    String?
  floor       String?
  roomNumber  String?
  locationTxt String?
  wizardMeta  Json?
  reporterId  String
  reporter    User              @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?             @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    IssueComment[]
  activities  IssueActivity[]
  attachments IssueAttachment[]
  openedAt    DateTime          @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, priority, createdAt])
  @@index([reporterId, createdAt])
  @@index([assigneeId, status])
  @@index([category, status])
}

model IssueComment {
  id         String   @id @default(uuid())
  issueId    String
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([issueId, createdAt])
  @@index([authorId, createdAt])
}

model IssueActivity {
  id         String      @id @default(uuid())
  issueId    String
  issue      Issue       @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User        @relation("IssueActor", fields: [actorId], references: [id], onDelete: Cascade)
  fromStatus IssueStatus?
  toStatus   IssueStatus?
  note       String?
  createdAt  DateTime    @default(now())

  @@index([issueId, createdAt])
  @@index([actorId, createdAt])
}

model IssueAttachment {
  id           String   @id @default(uuid())
  issueId      String
  issue        Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  fileUrl      String
  fileMimeType String?
  uploadedById String
  uploadedBy   User     @relation("IssueAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([issueId, createdAt])
}

model Announcement {
  id          String                 @id @default(uuid())
  title       String
  body        String
  category    AnnouncementCategory   @default(GENERAL)
  visibility  AnnouncementVisibility @default(PUBLIC)
  isSticky    Boolean                @default(false)
  isPublished Boolean                @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  authorId    String
  author      User                   @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  tags        AnnouncementOnTag[]
  reads       AnnouncementRead[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([isPublished, isSticky, publishedAt])
  @@index([category, visibility])
}

model AnnouncementTag {
  id           String              @id @default(uuid())
  name         String              @unique
  colorHex     String?
  announcements AnnouncementOnTag[]
  createdAt    DateTime            @default(now())
}

model AnnouncementOnTag {
  announcementId String
  tagId          String
  announcement   Announcement   @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  tag            AnnouncementTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([announcementId, tagId])
  @@index([tagId])
}

model AnnouncementRead {
  announcementId String
  userId         String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@id([announcementId, userId])
  @@index([userId, readAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  payload   Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

model Room {
  id                String                 @id @default(uuid())
  code              String                 @unique
  name              String
  type              RoomType               @default(CLASSROOM)
  building          String
  floor             String?
  capacity          Int
  features          Json?
  isActive          Boolean                @default(true)
  bookings          Booking[]
  availabilitySlots RoomAvailabilitySlot[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([building, isActive])
}

model RoomAvailabilitySlot {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String
  endTime   String
  isBlocked Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())

  @@index([roomId, dayOfWeek, startTime])
}

model Booking {
  id           String        @id @default(uuid())
  roomId       String
  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation("BookingRequester", fields: [userId], references: [id], onDelete: Cascade)
  title        String
  purpose      String?
  attendeeCount Int?
  startsAt     DateTime
  endsAt       DateTime
  status       BookingStatus @default(PENDING)
  approvedById String?
  approvedBy   User?         @relation("BookingApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([roomId, startsAt, endsAt])
  @@index([userId, startsAt])
  @@index([status, startsAt])
}
